+    const e = src.indexOf(endMarker, s + startMarker.length);
+    if (e === -1) { console.error(`MISSING SPLICE END [${label}]`); process.exit(1); }
+    const eol = src.lastIndexOf('\n', e) + 1;
+    src = src.slice(0, sol) + replacement + src.slice(eol);
+    count++;
