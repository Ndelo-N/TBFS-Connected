+                } else {
+                    box.checked = true;
+                }
+            }
+        }
+
+        /**
+         * Restore from cloud
+         */
+        `,
+'toggleAutoBackup');
+
+/* ---- restoreData: importJSON is the only restore path (F-08) ------------------ */
+splice(
